# Replace with your actual domain
yourdomain.com {
    header {
        # Security Headers
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Basic Authentication (Hash the password using `caddy hash-password`)
    basicauth /* {
        admin JDJhJDE0JDd2a3Z3... # Example hash
    }

    # Proxy Ollama API
    handle /ollama/* {
        uri strip_prefix /ollama
        reverse_proxy 127.0.0.1:11434 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            # Clear Origin to bypass Ollama's local CORS check
            header_up -Origin
        }
    }

    # Proxy OpenClaw Frontend
    handle /* {
        reverse_proxy 127.0.0.1:3000
    }
}
